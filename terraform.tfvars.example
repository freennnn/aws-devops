# AWS DevOps Project Configuration - EXAMPLE
# Copy this file to terraform.tfvars and customize the values

# Project settings
project_name = "rs-aws-devops"
aws_region   = "us-west-2"  # Change to your preferred region

# Network settings
vpc_cidr               = "10.0.0.0/16"
public_subnet_1_cidr   = "10.0.1.0/24"
public_subnet_2_cidr   = "10.0.2.0/24"
private_subnet_1_cidr  = "10.0.3.0/24"
private_subnet_2_cidr  = "10.0.4.0/24"
availability_zone_1    = "us-west-2a"
availability_zone_2    = "us-west-2b"
ssh_cidr_blocks        = ["YOUR_IP_ADDRESS/32"]  # IMPORTANT: Replace with your actual IP!

# Infrastructure options
enable_nat_gateway     = true   # Set to false for cheaper NAT instances
deploy_to_private      = false  # Set to true for production-like setup
enable_bastion_eip     = true   # Elastic IP for bastion host

# EC2 settings (Free Tier)
instance_type         = "t3.micro"  # Free Tier eligible
bastion_instance_type = "t3.micro"  # Free Tier eligible
key_name              = "your-aws-key-name"  # Your AWS key pair name

# S3 settings
app_bucket_name = "rs-aws-devops-app-bucket-YOURNAME"  # MUST be globally unique!

# Environment setting
environment = "prod" 